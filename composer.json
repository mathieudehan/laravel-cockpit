{
    "name": "mathieu/laravel-cockpit",
    "description": "A Laravel package to observe and act on your application — like Telescope but with actions.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cockpit", "monitoring", "dashboard", "devtools"],
    "authors": [
        {
            "name": "Mathieu Dehan",
            "email": "mathieu.dehan@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mathieu\\Cockpit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mathieu\\Cockpit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mathieu\\Cockpit\\CockpitServiceProvider"
            ],
            "aliases": {
                "Cockpit": "Mathieu\\Cockpit\\Facades\\Cockpit"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
